# ═══════════════════════════════════════════════════════════════
# My AI Brain — Environment Configuration
# ═══════════════════════════════════════════════════════════════

# ── Discord ──
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_COMMAND_PREFIX=!ask
TECH_WEBHOOK_UR=https://discord.com/api/webhooks/your_webhook_url_here
ALGO_WEBHOOK_URL=https://discord.com/api/webhooks/your_algo_webhook_url_here
JOB_WEBHOOK_URL=https://discord.com/api/webhooks/your_job_webhook_url_here
WEBHOOK_SECRET=your_secret_key_here

# ── LLM APIs ──
# Groq (LPU inference — ultra-low latency, <500ms for 70B models)
# Sign up: https://console.groq.com (free tier available)
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL_NAME=openrouter/auto
GEMINI_API_KEY=your_gemini_key_here
TAVILY_API_KEY=your_tavily_key_here

GITHUB_TOKEN=your_github_token_here
YOUTUBE_API_KEY=your_youtube_key_here

# ── Web Search ──
# Tavily API: https://app.tavily.com (free tier: 1000 searches/month)
# YouTube API: https://console.cloud.google.com/apis/credentials
# GitHub Token: https://github.com/settings/tokens

# ── Local LLM (Llama.cpp) ──
USE_LOCAL_LLM=false
LOCAL_LLM_URL=http://localhost:3002
LOCAL_LLM_TIMEOUT=10000

# ── Redis ──
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ── REST API ──
REST_API_PORT=3005
REST_API_KEY=change-me-to-a-random-secret-key

# ── Shadow Launching (Tier 2) ──
# Khi SHADOW_MODE=true, RouterAgent sẽ fork request sang shadow agent
# và log comparison (primary vs shadow) vào structured log → BigQuery.
# Shadow agents phải được bật trong AGENT_REGISTRY (enabled: true).
SHADOW_MODE=false

# ── Manim / FFmpeg ──
# Đường dẫn tùy chỉnh nếu manim/ffmpeg không nằm trong PATH
# MANIM_PATH=/usr/local/bin/manim
# FFMPEG_PATH=/usr/local/bin/ffmpeg
MANIM_RENDER_DIR=/tmp/manim-render
VIDEO_BASE_URL=
VIDEO_STORAGE_MODE=local

# ── Qdrant (optional) ──
USE_QDRANT=false
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=vectors

# ── Monitoring ──
GRAFANA_PASSWORD=change-me-in-production

# ── Feature Flags (tắt/bật tính năng để tiết kiệm tài nguyên) ──
# Voice Agent: dùng whisper.cpp + TTS API (tốn CPU/RAM + API cost)
ENABLE_VOICE=false
# Manim Agent: render video animation (cực kỳ tốn CPU/RAM, dễ crash)
ENABLE_MANIM=false
# Vision Agent: dùng Gemini Vision API (tốn token)
ENABLE_VISION=true
# EvoAgent: tự động tối ưu hệ thống (chạng nền, nhẹ)
ENABLE_EVO=true
# GraphAgent: knowledge graph sync (chạy nền, nhẹ)
ENABLE_GRAPH=true
# Self-Play: synthetic dataset generation (tốn LLM tokens)
ENABLE_SELF_PLAY=false
# HyDE: Hypothetical Document Embeddings (tốn thêm 1 LLM call/query)
ENABLE_HYDE=false

# ── Hybrid Search ──
HYBRID_BM25_WEIGHT=0.3

# ── RAG ──
DISCORD_SIMILARITY_THRESHOLD=0.6
DISCORD_MAX_RESULTS=4
DISCORD_WEB_SEARCH_LIMIT=3
