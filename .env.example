# ═══════════════════════════════════════════════════════════════
# My AI Brain — Environment Configuration
# ═══════════════════════════════════════════════════════════════

# ── Discord ──
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_COMMAND_PREFIX=!ask
DISCORD_WEBHOOK=https://discord.com/api/webhooks/your_webhook_url_here
WEBHOOK_SECRET=your_secret_key_here

# ── LLM APIs ──
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL_NAME=openrouter/auto
GEMINI_API_KEY=your_gemini_key_here
TAVILY_API_KEY=your_tavily_key_here

# ── Local LLM (Llama.cpp) ──
USE_LOCAL_LLM=false
LOCAL_LLM_URL=http://localhost:3002
LOCAL_LLM_TIMEOUT=10000

# ── Redis ──
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ── REST API ──
REST_API_PORT=3005
REST_API_KEY=change-me-to-a-random-secret-key

# ── Manim / FFmpeg ──
# Đường dẫn tùy chỉnh nếu manim/ffmpeg không nằm trong PATH
# MANIM_PATH=/usr/local/bin/manim
# FFMPEG_PATH=/usr/local/bin/ffmpeg
MANIM_RENDER_DIR=/tmp/manim-render
VIDEO_BASE_URL=
VIDEO_STORAGE_MODE=local

# ── Qdrant (optional) ──
USE_QDRANT=false
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=vectors

# ── Monitoring ──
GRAFANA_PASSWORD=change-me-in-production

# ── Embedding Cache ──
EMBEDDING_CACHE_TTL_MS=604800000
EMBEDDING_CACHE_MAX=10000

# ── Hybrid Search ──
HYBRID_BM25_WEIGHT=0.3

# ── RAG ──
DISCORD_SIMILARITY_THRESHOLD=0.6
DISCORD_MAX_RESULTS=4
DISCORD_WEB_SEARCH_LIMIT=3
