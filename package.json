{
  "name": "my-ai-brain",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node gateway.js",
    "dev": "concurrently -c \"cyan,magenta,yellow,green\" -n \"BOT,SERVER,CRON,WATCH\" \"npm run discord:bot\" \"npm run api\" \"npm run schedule\" \"npm run watch:library\"",
    "pipeline": "node pipeline_report_v2.js \"beginner\"",
    "pipeline:force": "node pipeline_report_v2.js \"beginner\" --force",
    "discord:bot": "node discord_bot.js",
    "schedule": "node scheduler.js",
    "cleanup": "node cleanup_artifacts.js",
    "cleanup:dry": "node cleanup_artifacts.js --dry-run",
    "watch:library": "node watch_library.js",
    "quiz": "node lib/flashcard_db.js --test",
    "db:backup": "node scripts/backup_db.js",
    "db:restore": "node scripts/restore_db.js",
    "api": "node rest_api_server.js",
    "admin": "node admin_dashboard.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --no-cache",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint . --ext .js --max-warnings=20",
    "format": "prettier --write \"**/*.js\" \"**/*.json\" \"**/*.md\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=20.0.0 <25.0.0"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "@google-cloud/bigquery": "^8.3.1",
    "@google/genai": "^2.8.0",
    "@langchain/core": "^1.1.48",
    "@langchain/google-genai": "^2.1.31",
    "@mozilla/readability": "^0.6.0",
    "@sqlite.org/sqlite-wasm": "^3.53.0-build1",
    "@tavily/core": "^0.7.5",
    "better-sqlite3": "^11.7.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "discord.js": "^14.16.0",
    "dotenv": "^17.4.2",
    "duck-duck-scrape": "^2.2.7",
    "edge-tts": "^1.0.1",
    "express": "^4.19.2",
    "jsdom": "^29.1.1",
    "node-cron": "^3.0.3",
    "node-sqlite3-wasm": "^0.8.58",
    "opusscript": "^0.0.8",
    "pdf-parse": "^1.1.1",
    "puppeteer-core": "^25.1.0",
    "search-engine-scraper": "^1.0.0",
    "serper": "^1.0.6",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "ts-fsrs": "^5.4.1",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "jest": "^29.7.0",
    "jest-circus": "^30.4.2",
    "node-gyp": "^10.3.1",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.11"
  }
