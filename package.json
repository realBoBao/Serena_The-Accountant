{
  "name": "my-ai-brain",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "concurrently -c \"cyan,magenta,yellow,green\" -n \"BOT,SERVER,CRON,WATCH\" \"npm run discord:bot\" \"npm run feedback\" \"npm run schedule\" \"npm run watch:library\"",
    "pipeline": "node pipeline_report_v2.js \"beginner\"",
    "pipeline:force": "node pipeline_report_v2.js \"beginner\" --force",
    "feedback": "node feedback_server.js",
    "analyze-text": "node analyze_text.js",
    "analyze-text-gemini": "node analyze_text_gemini.js",
    "analyze-pdf": "node analyze_pdf.js",
    "fetch-browser": "node browser_fetch.js",
    "discord:bot": "node discord_bot.js",
    "memory:archive": "node scripts/archive_memory.js",
    "schedule": "node scheduler.js",
    "cleanup": "node cleanup_artifacts.js",
    "cleanup:dry": "node cleanup_artifacts.js --dry-run",
    "cleanup:archive": "node cleanup_artifacts.js --archive",
    "cleanup:delete": "node cleanup_artifacts.js --delete",
    "watch:library": "node watch_library.js",
    "report": "node generate_report.js",
    "init:collections": "node init_collections.js",
    "quiz": "node lib/flashcard_db.js --test",
    "db:backup": "node scripts/backup_db.js",
    "db:restore": "node scripts/restore_db.js",
    "db:offsite": "node scripts/offsite_backup.js",
    "api": "node rest_api_server.js",
    "schedule:sync": "node scripts/sync_schedule.js",
    "admin": "node admin_dashboard.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint . --ext .js --max-warnings=20",
    "format": "prettier --write \"**/*.js\" \"**/*.json\" \"**/*.md\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@langchain/core": "^1.1.48",
    "@langchain/google-genai": "^2.1.31",
    "@langchain/openai": "^1.4.7",
    "@qdrant/js-client-rest": "^1.9.4",
    "@tavily/core": "^0.7.5",
    "bullmq": "^5.78.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "discord.js": "^14.16.0",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "graphology": "^0.26.0",
    "ioredis": "^5.11.0",
    "langchain": "^1.4.2",
    "neo4j-driver": "^6.0.1",
    "node-cron": "^3.0.3",
    "pdf-parse": "^1.1.1",
    "playwright": "^1.40.0",
    "prom-client": "^15.1.3",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "jest": "^29.7.0",
    "prettier": "^3.8.3"
  }
